{
  "framework": "vite",
  "crons": [
    {
      "path": "/api/orders/actions?action=monday-pipeline",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/orders/actions?action=health-check",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/orders/actions?action=daily-design-update",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/orders/actions?action=weekly-ads-debrief",
      "schedule": "0 20 * * 5"
    },
    {
      "path": "/api/orders/actions?action=weekly-ads-debrief",
      "schedule": "0 21 * * 5"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/public/results-lookup",
      "destination": "/api/orders/actions?action=public-results-lookup"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
