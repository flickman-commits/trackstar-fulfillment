{
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron/monday-pipeline",
      "schedule": "0 13 * * 1"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
