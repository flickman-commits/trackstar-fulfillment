// Trackstar Database Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Order {
  id                 String    @id @default(cuid())
  orderNumber        String    // Order number for this specific item (parentOrderNumber-lineItemIndex)
  parentOrderNumber  String    // Original Shopify/Etsy order number
  lineItemIndex      Int       @default(0) // Which line item this is (0, 1, 2, etc.)
  source             String    // "shopify" or "etsy"
  arteloOrderData    Json      // Full order object from Artelo
  shopifyOrderData   Json?     // Personalization data if Shopify
  etsyOrderData      Json?     // Receipt/personalization data if Etsy
  raceName           String
  raceYear           Int
  runnerName         String
  productSize        String
  frameType          String
  notes              String?   // Notes from Shopify (year corrections, etc.)
  hadNoTime          Boolean   @default(false) // Flag: customer entered "no time" in runner name
  status             String    @default("pending") // "pending", "missing_year", "ready", "flagged", "completed"
  researchedAt       DateTime?
  createdAt          DateTime  @default(now())

  // Trackstar order classification
  trackstarOrderType String    @default("standard") // "standard" | "custom" | "race_partner"
  // Note: race_partner rows reuse raceName as the partner name and
  // customerName/customerEmail as the partner contact — no schema change needed.

  // Custom order fields (populated from Shopify properties for custom orders)
  designStatus       String    @default("not_started") // "not_started" | "in_progress" | "awaiting_review" | "ready_to_send" | "done"
  dueDate            DateTime? // Computed: order created_at + 14 days
  customerEmail      String?   // Customer email from Shopify order
  customerName       String?   // Customer first name from Shopify order (for email template)
  bibNumberCustomer  String?   // Bib # provided by customer (custom orders only)
  timeCustomer       String?   // Time provided by customer (custom orders only)
  creativeDirection  String?   // Creative direction notes from customer
  isGift             Boolean   @default(false) // Whether this is a gift order
  proofSentAt        DateTime? // When proofs were last sent to customer (for follow-up tracking)
  designerNote       String?   // Optional note from designer sent with proofs (shown in approval portal)
  // Custom-order delay notification (Dan's "Notify Customer of Delay" button)
  delayNoticeSentAt  DateTime? // When the delay-notice email was sent
  delayNoticeDaysLate Int?     // How many days late we promised in that email

  // Shipping. Currently used by creator-sample orders to surface a real
  // "shipped" signal in the creator portal (status='completed' means "sent to
  // production", which is not the same as out-the-door).
  trackingNumber     String?
  trackingCarrier    String?   // Free-text: "USPS", "UPS", "FedEx", etc.
  shippedAt          DateTime?

  // Customer-confirmed race result, captured by the storefront Instant Lookup
  // widget on STANDARD race orders. Distinct from bibNumberCustomer/timeCustomer
  // above (those are free-text fields for CUSTOM "any race" orders).
  //   lookupVerified = true  → customer confirmed an official-results match
  //                            (same data the scraper would find, human-verified)
  //                  = false → customer typed it manually (still research as fallback)
  //                  = null  → no widget data (Etsy, or a PDP without the widget)
  //                            → research runs normally, exactly as before.
  // Phase 1 reads these to skip research when verified; Phase 0 only captures them.
  lookupVerified     Boolean?  // Did the data come from a confirmed official match?
  customerBib        String?   // Bib # from the widget (verified or manual)
  customerFinishTime String?   // Finish time from the widget (verified or manual)
  customerPace       String?   // Pace from the widget (only set on a verified match)
  customerEventType  String?   // Event/distance from the widget (e.g. "Marathon")
  // How the shopper arrived at their confirmed/typed result. Drives the
  // "outcome" chip on the order detail and helps debug widget behavior.
  //   "auto_match"          → single official-results match, customer confirmed
  //   "picked_from_list"    → multiple matches, customer picked one
  //   "manual_no_match"     → lookup ran, returned nothing → typed it in
  //   "manual_lookup_error" → endpoint errored / unreachable → typed it in
  //   "manual_rate_limited" → 429 → typed it in
  //   "manual_user_choice"  → customer chose "Enter info manually" themselves
  //   null                  → no widget data (Etsy / pre-widget order)
  lookupOutcome      String?

  // Personalization photo, captured by the storefront wizard's photo step.
  // Stores the Supabase Storage PATH, never a URL: the bucket is private and a
  // durable public link to a customer's photo is a privacy problem we could not
  // walk back. The dashboard mints a short-lived signed URL on demand via
  // /api/admin/photo-signed-url when a designer opens the order.
  //   null → no photo on this order (the overwhelming majority)
  photoPath          String?

  // Manual override fields (for customer corrections)
  yearOverride       Int?      // Override for raceYear
  raceNameOverride   String?   // Override for raceName
  runnerNameOverride String?   // Override for runnerName

  // Relations
  runnerResearch   RunnerResearch[]
  comments         OrderComment[]
  approvalToken    ApprovalToken?
  proofs           Proof[]
  messages         OrderMessage[]
  creatorSample    Creator?  @relation("CreatorSample") // Set iff this is a creator-program sample order

  @@unique([parentOrderNumber, lineItemIndex]) // Each line item is unique within an order
  @@index([orderNumber])
  @@index([parentOrderNumber]) // For grouping items from same order
  @@index([status])
  @@index([raceName, raceYear])
  @@index([trackstarOrderType])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([dueDate])
  @@index([designStatus])
}

model Race {
  id               Int       @id @default(autoincrement())
  raceName         String
  year             Int
  raceDate         DateTime
  eventTypes       Json      // Array like ["Marathon", "Half Marathon"]
  resultsUrl       String?
  resultsSiteType  String?
  location         String?
  weatherCondition String?   // "sunny", "cloudy", "rainy", or "snowy"
  weatherTemp      String?
  weatherFetchedAt DateTime?
  weatherDetails   String?   // JSON breakdown of how the weather was calculated (for the info popover)
  createdAt        DateTime  @default(now())

  // Relations
  runnerResearch   RunnerResearch[]

  @@unique([raceName, year])
  @@index([raceName])
  @@index([year])
}

model RunnerResearch {
  id             Int      @id @default(autoincrement())
  orderId        String   // Changed to orderId to link to Order.id instead
  raceId         Int
  runnerName     String
  bibNumber      String?
  officialTime   String?
  officialPace   String?
  eventType      String?  // "Marathon" or "Half Marathon"
  yearFound      Int?
  researchStatus String   @default("pending") // "found", "not_found", "ambiguous", "no_scraper", "year_not_configured", "upstream_error"
  // How this result was obtained:
  //   "scraper"          → found by the backend research scrape (default)
  //   "customer_verified" → customer confirmed an official-results match in the
  //                         storefront Instant Lookup widget (no runner scrape)
  source         String   @default("scraper")
  researchNotes  String?
  resultsUrl     String?  // URL where this runner's results were found
  // Candidate matches surfaced when no exact name match was found. Each item:
  // { name, bib?, time?, pace?, city?, state?, eventType?, resultsUrl? }
  // The dashboard renders these as Accept-button rows so the user can pick.
  possibleMatches Json?
  createdAt      DateTime @default(now())

  // Relations
  order          Order    @relation(fields: [orderId], references: [id])
  race           Race     @relation(fields: [raceId], references: [id])

  @@index([orderId])
  @@index([raceId])
  @@index([researchStatus])
}

model OrderComment {
  id        String   @id @default(cuid())
  orderId   String
  text      String?
  imageUrl  String?
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Two-way Q&A between the designer (Dan) and the customer for a custom order.
// The designer asks a question in the backend portal → the customer answers in
// the same token-gated approval portal they use for proofs → Dan gets pinged.
// No inbound email: the customer's reply is a token-validated POST from the
// portal, exactly like a proof revision request.
model OrderMessage {
  id             String   @id @default(cuid())
  orderId        String
  sender         String   // "designer" | "customer"
  body           String
  readByDesigner Boolean  @default(false) // false when a customer reply is awaiting Dan
  createdAt      DateTime @default(now())

  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ApprovalToken {
  id        String   @id @default(cuid())
  orderId   String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Proof {
  id               String   @id @default(cuid())
  orderId          String
  version          Int
  batch            Int      @default(1) // Which send-round this proof belongs to (1 = first send, 2 = first revision, etc.)
  imageUrl         String
  thumbnailUrl     String?  // Compressed ~200px thumbnail for grid views (saves egress bandwidth)
  fileName         String?
  status           String   @default("pending") // "pending" | "approved" | "revision_requested"
  customerFeedback String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Public Instant Lookup attempts, persisted so the admin "Recent Lookups"
// panel can see EVERY lookup regardless of which serverless instance handled
// it. In-memory ring buffers are per-function in Vercel, so they were invisible
// to the admin endpoint — this table replaces them.
//
// Names and IPs are anonymized before write (e.g. "M.H.(11)", "73.21.x.x").
// No PII stored. Indexed for fast "last N" + "by race" queries.
model LookupLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  race      String?
  year      Int?
  name      String   // anonymized: "M.H.(11)"
  outcome   String   // found | suggestions | not_found | off | upstream_error | rate_limited | bad_request | cached
  status    Int?
  ms        Int?
  ip        String   // anonymized: "73.21.x.x"
  cached    Boolean  @default(false)

  @@index([createdAt])
  @@index([race, createdAt])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Trackstar Creator Program
// -----------------------------------------------------------------------------
// A Creator is a person Matt invites to the program. They receive an invite
// link, land on the onboarding wizard, submit their race info + shipping, and
// get a free sample print. The sample is fulfilled through the existing
// Standard order queue (source = "creator_sample") so Elí processes it like
// any other standard order.
//
// Future phases add: briefs, content submissions, Meta ad tagging, attribution,
// and commission tracking. Those live in their own tables (added later).
model Creator {
  id                  String    @id @default(cuid())

  // Invite + portal access. Token doubles as the creator's persistent portal
  // credential — they bookmark /creator/<token> and return to it anytime.
  inviteToken         String    @unique
  invitedAt           DateTime  @default(now())
  onboardedAt         DateTime?

  // Profile (populated at onboarding)
  name                String?
  email               String?
  instagramHandle     String?
  tiktokHandle        String?

  // Application questions (the public landing page is framed as an
  // application — both fields collected during /apply onboarding).
  //   bestContentLinks: pasted URLs / handles of their best UGC examples
  //   whyWorkWithUs:    optional freeform pitch from the applicant
  bestContentLinks    String?
  whyWorkWithUs       String?

  // Race info for the sample print (required for the personalization)
  raceName            String?
  raceYear            Int?
  bibNumber           String?
  finishTime          String?

  // Product preferences for the sample
  productSize         String?
  frameType           String?

  // Shipping address
  shippingName        String?
  shippingAddress1    String?
  shippingAddress2    String?
  shippingCity        String?
  shippingState       String?
  shippingZip         String?
  shippingCountry     String?   @default("US")

  // Commission — flexible per creator. Matt sets these manually after onboarding.
  //   commissionModel: "free_product" | "flat_per_asset" | "rev_share" | "hybrid"
  //   commissionConfig: JSON e.g. { "per_asset_usd": 50, "percent": 10 }
  commissionModel     String    @default("free_product")
  commissionConfig    Json      @default("{}")
  commissionNotes     String?

  // Free-form admin notes about the creator (anything Matt wants to jot down).
  notes               String?

  // Whitelisting (Meta Partnership Ads). Optional — off by default.
  whitelistingEnabled Boolean   @default(false)
  metaPageId          String?

  // How this row was created:
  //   "admin_invite" → Matt generated an invite link in /creators
  //   "public_apply" → minted when someone clicked Apply on the public /apply page
  // Used to hide abandoned public applications (public_apply + never onboarded)
  // from the admin table so they don't clutter it with blank rows.
  source              String    @default("admin_invite")

  // Workflow status
  status              String    @default("invited") // "invited" | "applied" | "active" | "paused" | "denied"

  // Content delivery status — tracks whether the creator has handed over the
  // promised content. Distinct from `status` (which is program-level).
  //   "not_received" | "received" | "edited" | "posted"
  contentStatus       String    @default("not_received")

  // Link to the Standard Order that fulfills their sample.
  sampleOrderId       String?   @unique
  sampleOrder         Order?    @relation("CreatorSample", fields: [sampleOrderId], references: [id])

  // Briefs assigned to this creator — selected by Matt at invite time.
  briefAssignments    BriefAssignment[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([email])
}

// A Brief describes a style of content Matt wants creators to film. Matt
// curates these in /briefs and assigns them to creators at invite time (or
// later). The creator portal shows their assigned briefs as the directive
// for what to shoot.
model Brief {
  id             String   @id @default(cuid())
  title          String
  description    String?                // overall goal / context
  styleOfVideo   String?                // e.g. "POV reveal", "talking head"
  angle          String?                // messaging angle
  targetLength   String?                // e.g. "15-30s", "60-90s"
  // Information framework — "guardrails, not scripts". Creators get the
  // framework, not a line-by-line script, and find their own voice inside it.
  hooks          String?                // opening lines / hook options (newline-separated)
  emotion        String?                // the emotional lever the content should pull
  fomo           String?                // why the viewer should act now
  persona        String?                // who they're speaking to
  // Top-performing reference content — the "50 best videos" idea. URLs +
  // notes about why each works.
  examplesNotes  String?
  status         String   @default("active") // "active" | "archived"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    BriefAssignment[]

  @@index([status])
}

// Many-to-many between Creator and Brief. Matt picks which briefs a creator
// is working on — stored here so it can change over time.
model BriefAssignment {
  id         String   @id @default(cuid())
  briefId    String
  creatorId  String
  assignedAt DateTime @default(now())

  brief      Brief    @relation(fields: [briefId], references: [id], onDelete: Cascade)
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([briefId, creatorId])
  @@index([creatorId])
  @@index([briefId])
}

// One row per rate-limited request. Durable because Vercel runs each API route
// as a SEPARATE serverless instance — an in-memory counter in one is invisible
// to the others, so an attacker spreading requests across instances never trips
// the limit. (Same lesson as LookupLog: process memory is not shared state.)
//
// Rows are swept opportunistically on write; there's no need to keep them past
// the widest rate-limit window.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String   // "<bucket>:<ip>", e.g. "photo_upload:203.0.113"
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}
