# ─── Database (Supabase + Prisma) ───
DATABASE_URL="postgresql://your-connection-string-here?pgbouncer=true"
DIRECT_URL="postgresql://your-direct-connection-string-here"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── Shopify API (Client Credentials Flow) ───
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your-shopify-client-id-here
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret-here

# ─── Etsy API (OAuth 2.0 + PKCE) ───
ETSY_API_KEY=your-etsy-api-key-here
ETSY_SHARED_SECRET=your-etsy-shared-secret-here
ETSY_SHOP_ID=your-etsy-shop-id-here

# ─── Artelo API ───
ARTELO_API_KEY=your-artelo-api-key-here

# ─── Slack Webhooks ───
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-here
SLACK_PROOF_WEBHOOK_URL=https://hooks.slack.com/services/your-proof-webhook-here
SLACK_DM_WEBHOOK_URL=https://hooks.slack.com/services/your-dm-webhook-here

# ─── Email (Resend) ───
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=Trackstar <proofs@orders.trackstar.art>

# ─── Auth (server-side only — never exposed to the browser) ───
ADMIN_SECRET=your-admin-secret-here          # server-to-server header auth (crons, tooling)
ADMIN_PASSWORD=your-admin-password-here      # browser login password (checked server-side)
SESSION_SECRET=your-session-signing-secret   # HMAC key for session cookies; falls back to ADMIN_SECRET
CRON_SECRET=your-cron-secret-here

# ─── Client-side (VITE_ prefix required — these ARE shipped to the browser) ───
# Leave VITE_API_URL empty: the Vite dev proxy forwards /api to localhost:3001
# same-origin, so the session cookie is sent. Setting an absolute URL makes API
# calls cross-origin and the cookie won't ride along.
VITE_API_URL=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
