{% comment %}
  Trackstar Instant Lookup
  ------------------------
  Customer-facing race-result lookup for a product page (PDP). The race is
  fixed per product (e.g. "Vermont City Marathon"); the shopper enters their
  YEAR and RUNNER NAME, and this widget calls the public lookup endpoint to
  find their official result. On a match (or after manual entry) it fills the
  product form's personalization fields so the verified data rides along to
  fulfillment when they add to cart.

  INSTALL
    1. Copy this file into your theme at: blocks/trackstar-instant-lookup.liquid
    2. On the product template, add this block INSIDE the product information
       section (Theme editor → product template → product section → Add block →
       "Trackstar Instant Lookup"). Drag it next to the add-to-cart button.
    3. In the block settings, confirm the Race name and API base URL.

  HOW THE DATA REACHES FULFILLMENT
    On confirm, the widget writes these cart line-item properties (it fills the
    matching inputs in your product form if they exist, otherwise it injects
    hidden inputs). The order pipeline already reads these exact names:
      - "Runner Name (First & Last)"
      - "Race Year"
      - "Race Name"
      - "Bib #"
      - "Time"
      - "Pace"               (only on a verified match — blank on manual entry)
      - "Event"              (event/distance, only on a verified match)
      - "_lookup_verified"  (hidden: "true" = instant match, "false" = manual entry)
    The property names are configurable in the block settings if your theme
    uses different ones.

  SAFETY
    The endpoint is dark until PUBLIC_LOOKUP_ENABLED=true server-side, and the
    per-race allowlist (PUBLIC_LOOKUP_RACES) controls which races go live. If
    the endpoint is off or a race isn't enabled, the widget quietly falls back
    to manual entry — no dead ends.
{% endcomment %}

<div
  class="tsil"
  id="tsil-{{ block.id }}"
  data-race="{{ block.settings.race_name | default: product.title | escape }}"
  data-api-base="{{ block.settings.api_base | default: 'https://fast.trackstar.art' | escape }}"
  data-require-lookup="{{ block.settings.require_lookup }}"
  data-prop-runner="{{ block.settings.prop_runner | escape }}"
  data-prop-year="{{ block.settings.prop_year | escape }}"
  data-prop-race="{{ block.settings.prop_race | escape }}"
  data-prop-bib="{{ block.settings.prop_bib | escape }}"
  data-prop-time="{{ block.settings.prop_time | escape }}"
  data-prop-pace="{{ block.settings.prop_pace | escape }}"
  data-prop-event="{{ block.settings.prop_event | escape }}"
  data-prop-notime="{{ block.settings.prop_notime | escape }}"
  data-prop-gift="{{ block.settings.prop_gift | escape }}"
  data-prop-verified="{{ block.settings.prop_verified | escape }}"
  data-prop-outcome="{{ block.settings.prop_outcome | escape }}"
  style="--tsil-accent: {{ block.settings.accent_color | default: '#4600D6' }};"
  {{ block.shopify_attributes }}
>
  <div class="tsil__card">
    <div class="tsil__head" data-tsil-head>
      <h3 class="tsil__title">Runner Lookup</h3>
      <p class="tsil__sub tsil__sub--verified">Verified by Trackstar Instant Lookup</p>
    </div>

    {%- comment -%} STATE: search form {%- endcomment -%}
    <form class="tsil__form" data-tsil-state="search" autocomplete="off" novalidate>
      <div class="tsil__field">
        <label class="tsil__label" for="tsil-name-{{ block.id }}">Runner Name <span class="tsil__req" aria-hidden="true">*</span> <span class="tsil__opt">(First &amp; Last)</span></label>
        <input class="tsil__input" id="tsil-name-{{ block.id }}" name="tsil-name"
               type="text" autocomplete="off" placeholder="Ex: John Smith" maxlength="80" required>
      </div>
      <div class="tsil__field">
        <label class="tsil__label" for="tsil-year-{{ block.id }}">Race Year <span class="tsil__req" aria-hidden="true">*</span></label>
        <select class="tsil__input" id="tsil-year-{{ block.id }}" name="tsil-year" data-tsil-year required></select>
      </div>
      <button class="tsil__btn tsil__btn--primary" type="submit" data-tsil-submit>Find Results</button>
      <p class="tsil__error" data-tsil-error hidden></p>
    </form>

    {%- comment -%} STATE: loading {%- endcomment -%}
    <div class="tsil__loading" data-tsil-state="loading" hidden>
      <span class="tsil__spinner" aria-hidden="true"></span>
      <span data-tsil-loading-text>Searching results…</span>
    </div>

    {%- comment -%} STATE: result confirmation (single match, a picked suggestion, or manual entry) {%- endcomment -%}
    <div class="tsil__result" data-tsil-state="found" hidden>
      <p class="tsil__found-head" data-tsil-found-head>Is this you?</p>
      <div class="tsil__bigcard" data-tsil-found-card></div>
      <p class="tsil__print-note">*These details will be printed on your poster.</p>
      <label class="tsil__notime">
        <input class="tsil__notime-cb" type="checkbox" data-tsil-notime>
        <span>Don't want time &amp; pace on it? Check this box</span>
      </label>
      <div class="tsil__giftq">
        <span class="tsil__giftq-label">Is this a gift?</span>
        <label class="tsil__radio"><input type="radio" name="tsil-gift-{{ block.id }}" value="yes" data-tsil-gift> Yes</label>
        <label class="tsil__radio"><input type="radio" name="tsil-gift-{{ block.id }}" value="no" data-tsil-gift> No</label>
      </div>
      <p class="tsil__error" data-tsil-found-error hidden></p>
      <button class="tsil__btn tsil__btn--primary" type="button" data-tsil-confirm>Confirm info</button>
      <div class="tsil__minor">
        <button class="tsil__btn-link" type="button" data-tsil-reset>Search again</button>
        <button class="tsil__btn-link" type="button" data-tsil-manual-link>Enter info manually</button>
      </div>
    </div>

    {%- comment -%} STATE: multiple suggestions {%- endcomment -%}
    <div class="tsil__suggestions" data-tsil-state="suggestions" hidden>
      <p class="tsil__found-head">We found multiple results — select the one that's you</p>
      <p class="tsil__refine-hint" data-tsil-refine-hint hidden>Showing the first 10. Add or correct your first name to narrow it down.</p>
      <div class="tsil__match-list" data-tsil-suggestion-list></div>
      <div class="tsil__minor">
        <button class="tsil__btn-link" type="button" data-tsil-reset>Search again</button>
        <button class="tsil__btn-link" type="button" data-tsil-manual-link>Enter info manually</button>
      </div>
    </div>

    {%- comment -%} STATE: manual entry fallback {%- endcomment -%}
    <form class="tsil__form" data-tsil-state="manual" autocomplete="off" hidden novalidate>
      <p class="tsil__found-head" data-tsil-manual-note>Enter your result manually</p>
      <div class="tsil__field">
        <label class="tsil__label" for="tsil-mname-{{ block.id }}">Runner Name <span class="tsil__req" aria-hidden="true">*</span> <span class="tsil__opt">(First &amp; Last)</span></label>
        <input class="tsil__input" id="tsil-mname-{{ block.id }}" name="tsil-mname" type="text" placeholder="Ex: John Smith" maxlength="80" required>
      </div>
      <div class="tsil__field">
        <label class="tsil__label" for="tsil-myear-{{ block.id }}">Race Year <span class="tsil__req" aria-hidden="true">*</span></label>
        <select class="tsil__input" id="tsil-myear-{{ block.id }}" name="tsil-myear" data-tsil-myear required></select>
      </div>
      <div class="tsil__row">
        <div class="tsil__field">
          <label class="tsil__label" for="tsil-mbib-{{ block.id }}">Bib # <span class="tsil__opt">(optional)</span></label>
          <input class="tsil__input" id="tsil-mbib-{{ block.id }}" name="tsil-mbib" type="text" placeholder="Ex: 12345" maxlength="20">
        </div>
        <div class="tsil__field">
          <label class="tsil__label" for="tsil-mtime-{{ block.id }}">Finish time <span class="tsil__opt">(optional)</span></label>
          <input class="tsil__input" id="tsil-mtime-{{ block.id }}" name="tsil-mtime" type="text" placeholder="Ex: 3:45.19" maxlength="20">
        </div>
      </div>
      <p class="tsil__manual-hint">*If you don't know the time, pace, and bib number for the runner, we'll pull them from the official race results.</p>
      <p class="tsil__error" data-tsil-manual-error hidden></p>
      <button class="tsil__btn tsil__btn--primary" type="submit" data-tsil-manual-submit>Use these details</button>
      <button class="tsil__btn tsil__btn--ghost" type="button" data-tsil-reset>Back to lookup</button>
    </form>

    {%- comment -%} STATE: attached / success {%- endcomment -%}
    <div class="tsil__done" data-tsil-state="done" hidden>
      <div class="tsil__done-card">
        <span class="tsil__check" aria-hidden="true"></span>
        <div class="tsil__done-text">
          <p class="tsil__done-head">Confirmed</p>
          <p class="tsil__done-summary" data-tsil-done-summary></p>
        </div>
        <button class="tsil__btn-link tsil__done-edit" type="button" data-tsil-edit>Edit</button>
      </div>
      <p class="tsil__confirm-note">Click <strong>Add to Cart</strong> below to lock it in.</p>
    </div>
  </div>
</div>

<style>
  #tsil-{{ block.id }} {
    --tsil-accent-hover: #5A1AE6;
    --tsil-text: #1A1A1A;
    --tsil-muted: #666666;
    --tsil-border: #E0E0E0;
    --tsil-bg: #FFFFFF;
    --tsil-soft: #F5F5F5;
    margin: 1.25rem 0;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--font-body--family, 'Helvetica Neue', Helvetica, Arial, sans-serif);
    letter-spacing: -0.04em;
    color: var(--tsil-text);
  }
  /* Keep hidden states hidden — class display rules below would otherwise
     out-specify the browser's default [hidden] rule and show every state. */
  #tsil-{{ block.id }} [hidden] { display: none !important; }
  /* When the intro is collapsed (results view), drop the leading gap. */
  #tsil-{{ block.id }} .tsil__head[hidden] ~ [data-tsil-state] { margin-top: 0; }
  /* Smooth fade-in between phases of the lookup (search → loading → found /
     suggestions / manual → done). Quick (.22s) so it never feels laggy. */
  #tsil-{{ block.id }} [data-tsil-state] {
    transition: opacity .22s ease, transform .22s ease;
  }
  #tsil-{{ block.id }} [data-tsil-state].tsil--entering {
    opacity: 0;
    transform: translateY(6px);
  }
  @media (prefers-reduced-motion: reduce) {
    #tsil-{{ block.id }} [data-tsil-state] { transition: none; }
    #tsil-{{ block.id }} [data-tsil-state].tsil--entering { opacity: 1; transform: none; }
  }
  #tsil-{{ block.id }} .tsil__card {
    border: 1px solid var(--tsil-border);
    background: var(--tsil-bg);
    padding: 1.5rem;
  }
  /* Header is left-aligned: logo (or title) sits at the left edge. */
  #tsil-{{ block.id }} .tsil__head { text-align: left; }
  #tsil-{{ block.id }} .tsil__logo { display: inline-block; height: 34px; width: auto; max-width: 75%; }
  #tsil-{{ block.id }} .tsil__title { margin: 0 0 .2rem; font-size: 1.35rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.04em; }
  #tsil-{{ block.id }} .tsil__sub { margin: .35rem 0 0; color: var(--tsil-muted); font-size: .8rem; line-height: 1.4; }
  /* "Verified by Trackstar Instant Lookup" — small uppercase brand badge. */
  #tsil-{{ block.id }} .tsil__sub--verified {
    margin: .25rem 0 0;
    font-size: .65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--tsil-muted);
  }
  /* Required-field asterisk (after Runner Name / Race Year). */
  #tsil-{{ block.id }} .tsil__req {
    color: var(--tsil-accent);
    font-weight: 700;
    margin-left: .1rem;
  }
  /* Italic "*we'll pull them..." hint under the optional manual fields. */
  #tsil-{{ block.id }} .tsil__manual-hint {
    margin: -.2rem 0 0;
    font-style: italic;
    font-size: .75rem;
    line-height: 1.4;
    letter-spacing: -0.04em;
    color: var(--tsil-muted);
  }
  #tsil-{{ block.id }} .tsil__form { display: grid; gap: .9rem; margin-top: 1.25rem; }
  #tsil-{{ block.id }} .tsil__row { display: grid; grid-template-columns: 1fr 1fr; gap: .9rem; }
  #tsil-{{ block.id }} .tsil__field { display: grid; gap: .35rem; }
  #tsil-{{ block.id }} .tsil__label { font-size: .9rem; font-weight: 500; letter-spacing: -0.04em; }
  #tsil-{{ block.id }} .tsil__opt { font-weight: 400; color: var(--tsil-muted); }
  #tsil-{{ block.id }} .tsil__input {
    width: 100%;
    box-sizing: border-box;
    padding: .7rem .8rem;
    border: 1px solid var(--tsil-border);
    border-radius: 0;
    font-family: inherit;
    font-size: 1rem;
    letter-spacing: -0.04em;
    color: var(--tsil-text);
    background: var(--tsil-bg);
  }
  #tsil-{{ block.id }} .tsil__input:focus {
    outline: none;
    border-color: var(--tsil-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--tsil-accent) 25%, transparent);
  }
  /* Lighter placeholder so the example text reads as a hint, not real input. */
  #tsil-{{ block.id }} .tsil__input::placeholder {
    color: var(--tsil-muted);
    opacity: .55;
  }
  #tsil-{{ block.id }} .tsil__btn {
    width: 100%;
    padding: 12px 24px;
    border-radius: 0;
    font-family: inherit;
    font-size: .95rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background-color .15s ease, opacity .15s ease;
  }
  #tsil-{{ block.id }} .tsil__btn:disabled { opacity: .55; cursor: progress; }
  #tsil-{{ block.id }} .tsil__btn--primary { background: var(--tsil-accent); color: #FFFFFF; }
  #tsil-{{ block.id }} .tsil__btn--primary:hover { background: var(--tsil-accent-hover); }
  #tsil-{{ block.id }} .tsil__btn--ghost { background: transparent; color: var(--tsil-muted); border-color: var(--tsil-border); }
  #tsil-{{ block.id }} .tsil__btn--ghost:hover { color: var(--tsil-text); border-color: var(--tsil-text); }
  #tsil-{{ block.id }} .tsil__error { margin: 0; color: #B42318; font-size: .9rem; letter-spacing: -0.04em; }
  #tsil-{{ block.id }} .tsil__loading { display: flex; align-items: center; gap: .6rem; margin-top: 1.25rem; color: var(--tsil-muted); font-size: 1rem; }
  #tsil-{{ block.id }} .tsil__spinner {
    width: 18px; height: 18px; border-radius: 50%;
    border: 2px solid var(--tsil-border);
    border-top-color: var(--tsil-accent);
    animation: tsil-spin .7s linear infinite;
  }
  @keyframes tsil-spin { to { transform: rotate(360deg); } }
  #tsil-{{ block.id }} .tsil__result, #tsil-{{ block.id }} .tsil__suggestions, #tsil-{{ block.id }} .tsil__done { margin-top: 1.25rem; display: grid; gap: .75rem; }
  #tsil-{{ block.id }} .tsil__found-head { margin: 0; font-weight: 700; font-size: 1.35rem; line-height: 1.15; letter-spacing: -0.04em; }
  #tsil-{{ block.id }} .tsil__refine-hint { margin: -.35rem 0 0; color: var(--tsil-muted); font-size: .8rem; line-height: 1.4; letter-spacing: -0.04em; }
  /* Quiet inline italic note (used in the green success card). No callout box. */
  #tsil-{{ block.id }} .tsil__confirm-note {
    margin: 0;
    font-style: italic;
    font-size: .8rem;
    line-height: 1.4;
    letter-spacing: -0.04em;
    color: var(--tsil-muted);
  }
  #tsil-{{ block.id }} .tsil__match, #tsil-{{ block.id }} .tsil__match-list { display: grid; gap: .5rem; }
  #tsil-{{ block.id }} .tsil__match-card {
    text-align: left;
    width: 100%;
    border: 1px solid var(--tsil-border);
    border-radius: 0;
    padding: .75rem .85rem;
    background: var(--tsil-soft);
    font-family: inherit;
    letter-spacing: -0.04em;
    cursor: pointer;
  }
  #tsil-{{ block.id }} button.tsil__match-card:hover { border-color: var(--tsil-accent); }
  #tsil-{{ block.id }} .tsil__match-name { font-weight: 700; font-size: 1.05rem; }
  #tsil-{{ block.id }} .tsil__match-meta { color: var(--tsil-muted); font-size: .9rem; margin-top: .15rem; }

  /* ---- Big result card (confirmation screen) ---- */
  #tsil-{{ block.id }} .tsil__bigcard {
    border: 1px solid var(--tsil-border);
    border-left: 3px solid var(--tsil-accent);
    background: var(--tsil-soft);
    padding: 1.1rem 1.15rem;
    display: grid;
    gap: .9rem;
  }
  #tsil-{{ block.id }} .tsil__bc-primary { display: grid; gap: .8rem; }
  #tsil-{{ block.id }} .tsil__bc-secondary {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem 1.6rem;
    padding-top: .25rem;
    border-top: 1px solid var(--tsil-border);
  }
  #tsil-{{ block.id }} .tsil__bc-label {
    font-size: .65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--tsil-muted);
    margin-bottom: .15rem;
  }
  #tsil-{{ block.id }} .tsil__bc-value { font-weight: 700; letter-spacing: -0.04em; line-height: 1.1; }
  /* Name + time are the heroes of the card. */
  #tsil-{{ block.id }} .tsil__bc-field--name .tsil__bc-value { font-size: 1.6rem; }
  #tsil-{{ block.id }} .tsil__bc-field--time .tsil__bc-value { font-size: 1.6rem; color: var(--tsil-accent); }
  #tsil-{{ block.id }} .tsil__bc-field--muted .tsil__bc-value { font-weight: 500; font-size: 1rem; }
  /* When "no time" is checked, the value reads "No time" / "No pace" in the
     same big purple style as a real result — visually consistent so the
     shopper sees exactly what will (and won't) appear on the poster. */

  /* Italic "*printed on your poster" note, sits just under the data card. */
  #tsil-{{ block.id }} .tsil__print-note {
    margin: -.4rem 0 .1rem;
    font-style: italic;
    font-size: .8rem;
    line-height: 1.4;
    letter-spacing: -0.04em;
    color: var(--tsil-muted);
  }

  /* ---- Is-this-a-gift radio group (required) ---- */
  #tsil-{{ block.id }} .tsil__giftq { display: flex; align-items: center; flex-wrap: wrap; gap: .5rem 1.1rem; font-size: .9rem; letter-spacing: -0.04em; }
  #tsil-{{ block.id }} .tsil__giftq-label { font-weight: 500; }
  #tsil-{{ block.id }} .tsil__radio { display: inline-flex; align-items: center; gap: .35rem; cursor: pointer; }
  #tsil-{{ block.id }} .tsil__radio input { width: 16px; height: 16px; accent-color: var(--tsil-accent); cursor: pointer; }

  /* ---- No-time checkbox ---- */
  #tsil-{{ block.id }} .tsil__notime {
    display: flex;
    align-items: flex-start;
    gap: .55rem;
    font-size: .85rem;
    line-height: 1.35;
    letter-spacing: -0.04em;
    color: var(--tsil-text);
    cursor: pointer;
  }
  #tsil-{{ block.id }} .tsil__notime-cb { margin-top: .15rem; width: 16px; height: 16px; accent-color: var(--tsil-accent); cursor: pointer; flex: 0 0 auto; }

  /* ---- Minor (secondary) text-link actions ---- */
  #tsil-{{ block.id }} .tsil__minor { display: flex; flex-wrap: wrap; gap: 1.1rem; margin-top: .15rem; }
  #tsil-{{ block.id }} .tsil__btn-link {
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: .8rem;
    letter-spacing: -0.04em;
    color: var(--tsil-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }
  #tsil-{{ block.id }} .tsil__btn-link:hover { color: var(--tsil-text); }

  /* ---- Done / success: green, collapsed, animated checkmark ---- */
  #tsil-{{ block.id }} .tsil__done-card {
    display: flex;
    align-items: center;
    gap: .8rem;
    padding: 1rem 1.1rem;
    background: #ECFDF3;
    border: 1px solid #A6F4C5;
    border-left: 3px solid #12B76A;
    animation: tsil-done-in .35s ease-out both;
  }
  @keyframes tsil-done-in {
    from { opacity: 0; transform: translateY(6px) scale(.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  #tsil-{{ block.id }} .tsil__check {
    flex: 0 0 auto;
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #12B76A;
    position: relative;
    transform: scale(0);
    animation: tsil-pop .35s cubic-bezier(.2,1.3,.5,1) .12s both;
  }
  #tsil-{{ block.id }} .tsil__check::after {
    content: "";
    position: absolute;
    left: 9px; top: 5px;
    width: 6px; height: 11px;
    border: solid #FFFFFF;
    border-width: 0 2.5px 2.5px 0;
    transform: rotate(45deg) scale(0);
    transform-origin: center;
    animation: tsil-check .2s ease-out .32s both;
  }
  @keyframes tsil-pop { to { transform: scale(1); } }
  @keyframes tsil-check { from { transform: rotate(45deg) scale(0); } to { transform: rotate(45deg) scale(1); } }
  #tsil-{{ block.id }} .tsil__done-text { flex: 1 1 auto; min-width: 0; }
  #tsil-{{ block.id }} .tsil__done-head { margin: 0; font-weight: 700; font-size: 1rem; letter-spacing: -0.04em; color: #027A48; }
  #tsil-{{ block.id }} .tsil__done-summary { margin: .1rem 0 0; font-weight: 700; font-size: 1.05rem; letter-spacing: -0.04em; color: var(--tsil-text); overflow-wrap: anywhere; }
  #tsil-{{ block.id }} .tsil__done-edit { flex: 0 0 auto; }
</style>

<script>
  (function () {
    var root = document.getElementById('tsil-{{ block.id }}');
    if (!root) return;

    var cfg = {
      race: root.getAttribute('data-race') || '',
      apiBase: (root.getAttribute('data-api-base') || '').replace(/\/+$/, ''),
      requireLookup: root.getAttribute('data-require-lookup') === 'true',
      props: {
        runner: root.getAttribute('data-prop-runner'),
        year: root.getAttribute('data-prop-year'),
        race: root.getAttribute('data-prop-race'),
        bib: root.getAttribute('data-prop-bib'),
        time: root.getAttribute('data-prop-time'),
        pace: root.getAttribute('data-prop-pace'),
        event: root.getAttribute('data-prop-event'),
        notime: root.getAttribute('data-prop-notime'),
        gift: root.getAttribute('data-prop-gift'),
        verified: root.getAttribute('data-prop-verified'),
        outcome: root.getAttribute('data-prop-outcome')
      }
    };

    var states = {};
    root.querySelectorAll('[data-tsil-state]').forEach(function (el) {
      states[el.getAttribute('data-tsil-state')] = el;
    });

    // Disable browser autofill / saved-contact suggestions on our text inputs.
    // Chrome ignores autocomplete="off" for name-like fields, so we also use the
    // readonly-until-focus guard: the field is readonly on load (autofill skips
    // readonly fields) and becomes editable the instant the shopper interacts.
    root.querySelectorAll('input[type="text"]').forEach(function (el) {
      el.setAttribute('autocomplete', 'off');
      el.setAttribute('autocorrect', 'off');
      el.setAttribute('spellcheck', 'false');
      el.setAttribute('readonly', 'readonly');
      var unlock = function () { el.removeAttribute('readonly'); };
      el.addEventListener('focus', unlock);
      el.addEventListener('pointerdown', unlock);
      el.addEventListener('touchstart', unlock);
    });

    var headEl = root.querySelector('[data-tsil-head]');
    function show(state) {
      Object.keys(states).forEach(function (k) { states[k].hidden = (k !== state); });
      // Collapse the heading/subheading intro once we're past the search step.
      if (headEl) headEl.hidden = (state !== 'search');
      // Fade the newly-visible state in from a few pixels below. The double
      // requestAnimationFrame lets the browser paint the `.tsil--entering`
      // class BEFORE we remove it, so the transition triggers.
      var next = states[state];
      if (next) {
        next.classList.add('tsil--entering');
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            next.classList.remove('tsil--entering');
          });
        });
      }
    }

    // Populate the year dropdowns (search + manual): current year back 15
    // years, newest first. Manual mirrors search so the shopper can correct
    // the year from the manual form too.
    var nowYear = new Date().getFullYear();
    var yearSelects = root.querySelectorAll('[data-tsil-year], [data-tsil-myear]');
    yearSelects.forEach(function (sel) {
      for (var y = nowYear; y >= nowYear - 15; y--) {
        var opt = document.createElement('option');
        opt.value = String(y);
        opt.textContent = String(y);
        sel.appendChild(opt);
      }
    });

    var errorEl = root.querySelector('[data-tsil-error]');
    function setError(msg) {
      if (!msg) { errorEl.hidden = true; errorEl.textContent = ''; return; }
      errorEl.hidden = false;
      errorEl.textContent = msg;
    }

    // The result currently being confirmed (from a single match, a picked
    // suggestion, or manual entry). _verified flags whether it came from an
    // official-results match (true) or was typed manually (false).
    var pendingResult = null;

    // ---- result rendering helpers ----
    // Compact meta for the suggestions LIST — event type, bib, and time (no pace).
    function fmtListMeta(m) {
      var bits = [];
      if (m.eventType) bits.push(m.eventType);
      if (m.bib) bits.push('Bib ' + m.bib);
      if (m.time) bits.push(m.time);
      return bits.join(' · ');
    }

    // Normalize a runner name to Title Case so the poster never goes out as
    // "matt hickman" (customer typo) or "ADRIAN GARCIA" (some timing platforms
    // return all-caps from official results). Handles common edge cases:
    // McDonnell, O'Brien, hyphenated names. Preserves diacritics.
    function toTitleCase(name) {
      if (!name) return name;
      var out = String(name).toLowerCase();
      // Capitalize the first letter, and every letter that follows a space,
      // hyphen, or apostrophe. Unicode letter class keeps diacritics intact.
      out = out.replace(/(^|[\s\-'])(\p{L})/gu, function (_, sep, ch) {
        return sep + ch.toUpperCase();
      });
      // "Mcdonnell" → "McDonnell", "Mckenna" → "McKenna".
      out = out.replace(/\bMc(\p{Ll})/gu, function (_, ch) {
        return 'Mc' + ch.toUpperCase();
      });
      return out;
    }

    // Render the big, labeled confirmation card. `noTime` greys out time/pace.
    function renderBigCard(r, noTime) {
      var card = root.querySelector('[data-tsil-found-card]');
      card.className = 'tsil__bigcard' + (noTime ? ' is-notime' : '');
      card.innerHTML = '';

      function field(label, value, mods) {
        var f = document.createElement('div');
        f.className = 'tsil__bc-field ' + mods;
        var l = document.createElement('div'); l.className = 'tsil__bc-label'; l.textContent = label;
        var v = document.createElement('div'); v.className = 'tsil__bc-value'; v.textContent = value;
        f.appendChild(l); f.appendChild(v);
        return f;
      }

      // Title-case the name for display. The cart property is also normalized
      // (in confirmInfo) so what they see here is exactly what gets printed.
      var name = toTitleCase(r.name || root.querySelector('[name="tsil-name"]').value);

      // Primary block — name + time are the heroes.
      var primary = document.createElement('div');
      primary.className = 'tsil__bc-primary';
      primary.appendChild(field('Runner', name || '—', 'tsil__bc-field--name'));
      // Always show the "Finish time" label. When no-time is ticked, the value
      // reads "No time" in the same big purple style — visually consistent so
      // the shopper sees exactly what will / won't appear on the poster.
      if (noTime) {
        primary.appendChild(field('Finish time', 'No time', 'tsil__bc-field--time'));
      } else if (r.time) {
        primary.appendChild(field('Finish time', r.time, 'tsil__bc-field--time'));
      }
      card.appendChild(primary);

      // Secondary block — smaller labeled details.
      var secondary = document.createElement('div');
      secondary.className = 'tsil__bc-secondary';
      if (r.bib) secondary.appendChild(field('Bib', r.bib, 'tsil__bc-field--muted tsil__bc-field--bib'));
      // Pace: show "No pace" when ticked (mirroring the time treatment) so the
      // shopper sees both will be omitted, not just hidden from the card.
      if (noTime) {
        secondary.appendChild(field('Pace', 'No pace', 'tsil__bc-field--muted tsil__bc-field--pace'));
      } else if (r.pace) {
        secondary.appendChild(field('Pace', r.pace + ' /mi', 'tsil__bc-field--muted tsil__bc-field--pace'));
      }
      if (r.eventType) secondary.appendChild(field('Event', r.eventType, 'tsil__bc-field--muted tsil__bc-field--event'));
      if (secondary.children.length) card.appendChild(secondary);
    }

    // ---- write data into the product form ----
    function findProductForm() {
      return document.querySelector('form[action$="/cart/add"], form[action*="/cart/add"]');
    }
    // Sets (or clears) a line-item property. An EMPTY value removes any hidden
    // input we injected, so we never ship a stray empty property (important for
    // the "No time" flag, which the backend treats as present == true).
    function setProp(form, key, value) {
      if (!key) return;
      var val = value == null ? '' : String(value);
      var field = form.querySelector('input[name="properties[' + key + ']"], textarea[name="properties[' + key + ']"], select[name="properties[' + key + ']"]');
      if (field) {
        if (val === '' && field.hasAttribute('data-tsil-injected')) { field.remove(); return; }
        field.value = val;
        field.dispatchEvent(new Event('input', { bubbles: true }));
        field.dispatchEvent(new Event('change', { bubbles: true }));
        return;
      }
      if (val === '') return; // nothing to set, nothing to inject
      var hidden = document.createElement('input');
      hidden.type = 'hidden';
      hidden.name = 'properties[' + key + ']';
      hidden.value = val;
      hidden.setAttribute('data-tsil-injected', key);
      form.appendChild(hidden);
    }

    function setSubmitDisabled(disabled) {
      if (!cfg.requireLookup) return;
      var form = findProductForm();
      if (!form) return;
      form.querySelectorAll('[type="submit"], [name="add"]').forEach(function (btn) {
        btn.disabled = disabled;
      });
    }
    // If lookup is required, lock add-to-cart until a result is confirmed.
    setSubmitDisabled(true);

    // Race name to write to the cart. The lookup endpoint returns the canonical
    // race name (e.g. "Mesa Marathon" instead of the product title "Mesa
    // Marathon Personalized Race Print"). We default to whatever the block was
    // configured with, then upgrade to the canonical name on a successful API
    // call. Manual entry keeps the configured value.
    var pendingRaceName = cfg.race;
    // How the shopper got here — see the values in confirmInfo's comments.
    var pendingOutcome = null;
    // Why the manual-entry form was shown (or null if we never went manual).
    // Lets us record the outcome when the shopper submits the manual form.
    var pendingFallbackReason = null;

    // Show the confirmation screen for a chosen result (does NOT write to cart yet).
    function selectResult(result, verified, heading, outcome) {
      pendingResult = result;
      pendingResult._verified = verified;
      pendingOutcome = outcome || null;
      var cb = root.querySelector('[data-tsil-notime]');
      if (cb) cb.checked = false;
      root.querySelectorAll('[data-tsil-gift]').forEach(function (r) { r.checked = false; });
      setFoundError('');
      root.querySelector('[data-tsil-found-head]').textContent = heading;
      renderBigCard(result, false);
      show('found');
    }

    // Final lock-in — write the cart properties and collapse to the green success card.
    var foundErrorEl = root.querySelector('[data-tsil-found-error]');
    function setFoundError(msg) {
      if (!foundErrorEl) return;
      if (!msg) { foundErrorEl.hidden = true; foundErrorEl.textContent = ''; return; }
      foundErrorEl.hidden = false;
      foundErrorEl.textContent = msg;
    }

    function confirmInfo() {
      if (!pendingResult) return;
      var noTime = !!(root.querySelector('[data-tsil-notime]') || {}).checked;
      // "Is this a gift?" is required — block confirm until answered.
      var giftRadio = root.querySelector('[data-tsil-gift]:checked');
      if (!giftRadio) { setFoundError('Please let us know if this is a gift.'); return; }
      setFoundError('');
      var isGift = giftRadio.value === 'yes';
      var form = findProductForm();
      var year = root.querySelector('[name="tsil-year"]').value;
      // Title-case so the poster always reads "Matt Hickman", never the typo
      // "matt hickman" the customer typed nor "MATT HICKMAN" from some timing
      // platforms' all-caps result data. Matches the confirm-screen display.
      var name = toTitleCase(pendingResult.name || root.querySelector('[name="tsil-name"]').value);
      if (form) {
        setProp(form, cfg.props.runner, name);
        setProp(form, cfg.props.year, year);
        // pendingRaceName is the CANONICAL race name (e.g. "Mesa Marathon")
        // returned by the lookup. Falls back to cfg.race (block setting →
        // product title) for manual entry or when canonicalization fails.
        setProp(form, cfg.props.race, pendingRaceName);
        setProp(form, cfg.props.bib, pendingResult.bib || '');
        // "No time" omits time + pace from the poster and sends the backend flag.
        setProp(form, cfg.props.time, noTime ? '' : (pendingResult.time || ''));
        setProp(form, cfg.props.pace, noTime ? '' : (pendingResult.pace || ''));
        setProp(form, cfg.props.event, pendingResult.eventType || '');
        setProp(form, cfg.props.verified, pendingResult._verified ? 'true' : 'false');
        // Values mirror Easify exactly so the fulfillment pipeline reads them
        // identically: "No time" => "No time", "Gift" => "This is a gift".
        setProp(form, cfg.props.notime, noTime ? 'No time' : '');
        setProp(form, cfg.props.gift, isGift ? 'This is a gift' : '');
        // Hidden outcome flag — tells the fulfillment dashboard HOW the shopper
        // arrived at this result so we can debug widget behavior per-order.
        // Values: auto_match, picked_from_list, manual_no_match,
        //         manual_lookup_error, manual_rate_limited, manual_user_choice.
        if (pendingOutcome) setProp(form, cfg.props.outcome, pendingOutcome);
      }
      setSubmitDisabled(false);
      var summary = name + (noTime ? ' · No time' : (pendingResult.time ? ' · ' + pendingResult.time : '')) + (isGift ? ' · Gift' : '');
      root.querySelector('[data-tsil-done-summary]').textContent = summary;
      show('done');
    }

    // ---- the lookup call ----
    function doLookup(name, year) {
      setError('');
      show('loading');
      root.querySelector('[data-tsil-loading-text]').textContent = 'Searching ' + cfg.race + ' results…';

      var url = cfg.apiBase + '/api/public/results-lookup'
        + '?race=' + encodeURIComponent(cfg.race)
        + '&year=' + encodeURIComponent(year)
        + '&name=' + encodeURIComponent(name);

      // cache: 'no-store' guarantees the browser/CDN doesn't return a stale
      // result for an identical-looking URL (some browsers cache GETs more
      // aggressively than the query-param difference would suggest). Without
      // this, going back, changing year, and re-searching the same name could
      // serve the previous response. Server also sets Cache-Control: no-store.
      fetch(url, { method: 'GET', cache: 'no-store', headers: { 'Accept': 'application/json' } })
        .then(function (r) {
          return r.json().catch(function () { return {}; }).then(function (data) {
            return { status: r.status, data: data };
          });
        })
        .then(function (res) {
          var data = res.data || {};
          // Capture canonical race name for the cart-property write.
          if (data.raceCanonical) pendingRaceName = data.raceCanonical;
          if (data.found && data.result) {
            selectResult(data.result, true, 'Is this you?', 'auto_match');
            return;
          }
          if (data.suggestions && data.suggestions.length) {
            // Outcome will be set when the shopper picks one (or falls to manual).
            pendingFallbackReason = 'manual_no_match';
            renderSuggestions(data.suggestions);
            root.querySelector('[data-tsil-refine-hint]').hidden = !data.truncated;
            show('suggestions');
            return;
          }
          // Everything else (not found, lookup off/404, error, rate-limited) → manual.
          prefillManual(name);
          if (res.status === 429) {
            root.querySelector('[data-tsil-manual-note]').textContent = 'Lots of lookups right now — please enter your result manually.';
            pendingFallbackReason = 'manual_rate_limited';
          } else if (res.status >= 500 || res.status === 0) {
            root.querySelector('[data-tsil-manual-note]').textContent = "We couldn't find this runner with instant lookup. No problem, just type it in and we'll find it for you.";
            pendingFallbackReason = 'manual_lookup_error';
          } else {
            root.querySelector('[data-tsil-manual-note]').textContent = "We couldn't find this runner with instant lookup. No problem, just type it in and we'll find it for you.";
            pendingFallbackReason = 'manual_no_match';
          }
          show('manual');
        })
        .catch(function () {
          prefillManual(name);
          root.querySelector('[data-tsil-manual-note]').textContent = "We couldn't reach the lookup service — please enter your result manually.";
          pendingFallbackReason = 'manual_lookup_error';
          show('manual');
        });
    }

    function renderSuggestions(list) {
      var wrap = root.querySelector('[data-tsil-suggestion-list]');
      wrap.innerHTML = '';
      list.forEach(function (m) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'tsil__match-card';
        var nameEl = document.createElement('div');
        nameEl.className = 'tsil__match-name';
        nameEl.textContent = toTitleCase(m.name) || 'Runner';
        var metaEl = document.createElement('div');
        metaEl.className = 'tsil__match-meta';
        metaEl.textContent = fmtListMeta(m) || 'Result on file';
        btn.appendChild(nameEl);
        btn.appendChild(metaEl);
        // Picking a suggestion goes to the same confirmation screen.
        btn.onclick = function () { selectResult(m, true, 'Confirm your result', 'picked_from_list'); };
        wrap.appendChild(btn);
      });
    }

    function prefillManual(name) {
      root.querySelector('[name="tsil-mname"]').value = name || '';
      // Also mirror the search year into the manual form so the shopper
      // doesn't have to re-pick it when they fall through to manual entry.
      var searchYear = root.querySelector('[name="tsil-year"]');
      var manualYear = root.querySelector('[name="tsil-myear"]');
      if (searchYear && manualYear && searchYear.value) manualYear.value = searchYear.value;
    }

    // ---- wire up events ----
    // Most timing platforms (Mika, Xacte, MyChipTime, RaceRoster…) index
    // results by LAST name. If the shopper types one word ("Sarah"), the
    // scraper queries that word as a surname and gets ~0 hits — silently
    // falling to manual entry would feel like a broken lookup. Require
    // first + last at the widget boundary so the user gets a clear hint.
    function hasFirstAndLast(s) {
      return String(s || '').trim().split(/\s+/).filter(Boolean).length >= 2;
    }

    states.search.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = root.querySelector('[name="tsil-name"]').value.trim();
      var year = root.querySelector('[name="tsil-year"]').value;
      if (!name) { setError('Please enter the runner name.'); return; }
      if (name.length > 80) { setError('Name is too long.'); return; }
      if (!hasFirstAndLast(name)) { setError('Please enter both first and last name.'); return; }
      doLookup(name, year);
    });

    states.manual.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = root.querySelector('[name="tsil-mname"]').value.trim();
      var myear = root.querySelector('[name="tsil-myear"]').value;
      var mErr = root.querySelector('[data-tsil-manual-error]');
      function mSetErr(msg) {
        if (!mErr) return;
        if (!msg) { mErr.hidden = true; mErr.textContent = ''; return; }
        mErr.hidden = false; mErr.textContent = msg;
      }
      mSetErr('');
      if (!name) { mSetErr('Please enter the runner name.'); return; }
      if (!hasFirstAndLast(name)) { mSetErr('Please enter both first and last name.'); return; }
      if (!myear) { mSetErr('Please select a race year.'); return; }
      // Sync the manual year back to the search year input so confirmInfo
      // (which reads from [name="tsil-year"]) writes the correct year to the
      // cart property, regardless of whether the shopper changed it here.
      var searchYear = root.querySelector('[name="tsil-year"]');
      if (searchYear) searchYear.value = myear;
      // Manual entry routes through the same confirmation screen as a match.
      // The outcome reflects WHY we ended up on manual (lookup error, no match,
      // rate-limited, or the shopper clicked "Enter info manually" themselves).
      selectResult({
        name: name,
        bib: root.querySelector('[name="tsil-mbib"]').value.trim(),
        time: root.querySelector('[name="tsil-mtime"]').value.trim()
      }, false, 'Confirm your details', pendingFallbackReason || 'manual_user_choice');
    });

    // Confirm button → lock in.
    root.querySelector('[data-tsil-confirm]').addEventListener('click', confirmInfo);

    // "Edit" on the success card → back to the confirmation screen (keeps the
    // selection + no-time choice), and re-locks add-to-cart until re-confirmed.
    var editBtn = root.querySelector('[data-tsil-edit]');
    if (editBtn) {
      editBtn.addEventListener('click', function () {
        if (!pendingResult) { show('search'); return; }
        setSubmitDisabled(true);
        var cb = root.querySelector('[data-tsil-notime]');
        renderBigCard(pendingResult, cb ? cb.checked : false);
        show('found');
      });
    }

    // No-time checkbox → live-update the card (grey out time/pace).
    var noTimeCb = root.querySelector('[data-tsil-notime]');
    if (noTimeCb) {
      noTimeCb.addEventListener('change', function () {
        if (pendingResult) renderBigCard(pendingResult, noTimeCb.checked);
      });
    }

    root.querySelectorAll('[data-tsil-reset]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        setError('');
        setSubmitDisabled(true);
        var cb = root.querySelector('[data-tsil-notime]');
        if (cb) cb.checked = false;
        root.querySelectorAll('[data-tsil-gift]').forEach(function (r) { r.checked = false; });
        setFoundError('');
        pendingRaceName = cfg.race;
        pendingOutcome = null;
        pendingFallbackReason = null;
        show('search');
      });
    });
    root.querySelectorAll('[data-tsil-manual-link]').forEach(function (link) {
      link.addEventListener('click', function () {
        prefillManual(root.querySelector('[name="tsil-name"]').value.trim());
        root.querySelector('[data-tsil-manual-note]').textContent = 'Enter your result manually.';
        // The shopper actively chose to type — distinct from "we couldn't find it".
        pendingFallbackReason = 'manual_user_choice';
        show('manual');
      });
    });

    show('search');
  })();
</script>

{% schema %}
{
  "name": "Trackstar Instant Lookup",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Header logo",
      "info": "Left-aligned logo shown at the top of the widget. When set, it replaces the Heading text. Upload the \"Trackstar Instant Lookup\" wordmark here."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Fallback shown only when no Header logo is uploaded.",
      "default": "Trackstar Instant Lookup"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Verify your runner's time."
    },
    {
      "type": "text",
      "id": "race_name",
      "label": "Race name override",
      "info": "Leave blank for normal use — the widget auto-detects the race from the product title, so this block works on your shared product template across all races. Only set this to force a specific race name on one product."
    },
    {
      "type": "text",
      "id": "api_base",
      "label": "API base URL",
      "default": "https://fast.trackstar.art"
    },
    {
      "type": "checkbox",
      "id": "require_lookup",
      "label": "Require lookup before add to cart",
      "info": "Disables the Add to cart button until a result is attached.",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Trackstar Purple by default. Used for buttons, links, and highlights.",
      "default": "#4600D6"
    },
    {
      "type": "header",
      "content": "Cart property names",
      "info": "Must match the line-item property names your product form / fulfillment pipeline uses."
    },
    { "type": "text", "id": "prop_runner", "label": "Runner name property", "default": "Runner Name (First & Last)" },
    { "type": "text", "id": "prop_year", "label": "Race year property", "default": "Race Year" },
    { "type": "text", "id": "prop_race", "label": "Race name property", "default": "Race Name" },
    { "type": "text", "id": "prop_bib", "label": "Bib property", "default": "Bib #" },
    { "type": "text", "id": "prop_time", "label": "Time property", "default": "Time" },
    { "type": "text", "id": "prop_pace", "label": "Pace property", "default": "Pace" },
    { "type": "text", "id": "prop_event", "label": "Event property", "default": "Event" },
    { "type": "text", "id": "prop_notime", "label": "No-time flag property", "default": "No time" },
    { "type": "text", "id": "prop_gift", "label": "Gift flag property", "default": "Gift" },
    { "type": "text", "id": "prop_verified", "label": "Verified flag property", "default": "_lookup_verified" },
    { "type": "text", "id": "prop_outcome", "label": "Outcome flag property", "default": "_lookup_outcome" }
  ],
  "presets": [
    {
      "name": "Trackstar Instant Lookup"
    }
  ]
}
{% endschema %}
